# Copy to .env.local and fill in values. Never commit .env.local.

# Public site URL (no trailing slash) — used for SEO: canonical URLs, Open Graph, sitemap, JSON-LD
# Production example: https://www.mindfulcrum.com
NEXT_PUBLIC_SITE_URL=https://www.mindfulcrum.com

# SMTP (required for /api/contact)
# Examples: Gmail (use an App Password), SendGrid, AWS SES SMTP, Mailgun, etc.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
# Use true for port 465, false for 587 STARTTLS
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password

# From address shown to recipients (defaults to SMTP_USER if unset)
MAIL_FROM=noreply@yourdomain.com

# Where contact form submissions are delivered (defaults to SMTP_USER if unset)
CONTACT_TO_EMAIL=hello@mindfulcrum.com

# Home-page booking (/api/booking) uses the same SMTP settings and sends:
# - confirmation to the patient
# - a copy to CONTACT_TO_EMAIL
